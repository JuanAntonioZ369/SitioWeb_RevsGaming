{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/payment.js": {
      "maxDuration": 10,
      "memory": 128
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://checkout.culqi.com https://fonts.googleapis.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://api.culqi.com https://checkout.culqi.com https://kyoyunuwfuujqdomdmlh.supabase.co; frame-src https://checkout.culqi.com; object-src 'none'; base-uri 'self';"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/changelog",      "destination": "/changelog/index.html" },
    { "source": "/docs",           "destination": "/docs/index.html" },
    { "source": "/register",       "destination": "/register.html" },
    { "source": "/legal/privacy",  "destination": "/legal/privacy.html" },
    { "source": "/legal/terms",    "destination": "/legal/terms.html" },
    { "source": "/account",        "destination": "/account.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/reset-password",  "destination": "/reset-password.html" },
    { "source": "/libro-reclamaciones", "destination": "/libro-reclamaciones.html" }
  ]
}
